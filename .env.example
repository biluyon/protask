# ── Protask environment ────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.

# Supabase (REQUIRED). The anon key is a public client key by design.
# Get both from your Supabase project: Settings → API.
VITE_SUPABASE_URL=https://pacpvhlonqdhhotrujxi.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBhY3B2aGxvbnFkaGhvdHJ1anhpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0MTI0ODMsImV4cCI6MjA5Nzk4ODQ4M30.uM2reNw0sGW0Va7kirKNGA0j-1J2xsH3SK6EVzqO170

# Private mode (OPTIONAL). Set to 'true' to require Google sign-in before the app
# loads — lock the instance to your own account so you can use the same public URL
# from any device without exposing your data. Requires:
#   1) Supabase Auth → enable Google provider (Client ID/Secret), add your URL(s)
#      to Site URL + Redirect URLs.
#   2) Run supabase/migrations/0005_rls.sql (enables Row-Level Security).
#   3) Sign in once, then disable new sign-ups in Supabase Auth.
# Leave blank/false for the default open (single-instance, no login) behavior.
VITE_REQUIRE_AUTH=

# Google Calendar (OPTIONAL). Leave blank to disable the calendar integration.
# Google Cloud Console → OAuth Web Client ID.
VITE_GOOGLE_CLIENT_ID=

# Google Calendar in local dev only (OPTIONAL):
# The /api/google-token serverless function runs on Vercel, not in `vite dev`.
# Set this to your deployed URL so local dev can reach it (e.g. https://your-app.vercel.app).
# In production this is same-origin and can stay blank.
VITE_API_BASE=

# ── Server-side only (set in Vercel → Project → Settings → Environment Variables) ──
# Needed ONLY for the Google Calendar token proxy. Never commit real values.
#   GOOGLE_CLIENT_ID=...        # same as the Web Client above
#   GOOGLE_CLIENT_SECRET=...    # OAuth client secret (server only)
#   APP_ORIGINS=https://your-app.vercel.app,http://localhost:5173  # optional CORS allowlist
